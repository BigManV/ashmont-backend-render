APP_ENV=local
APP_NAME=Ashmont Lead Qualification
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEV_AUTH_BYPASS=false
DEV_MOCK_DATA=false

DATABASE_URL=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
INTAKE_API_KEY=
TOOL_API_KEY=

RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
RETELL_CREATE_CALL_URL=https://api.retellai.com/v2/create-phone-call
# Optional. When set, this key is used to verify the X-Retell-Signature webhook
# header. If unset, RETELL_API_KEY is used (Retell signs webhooks with the API key).
RETELL_WEBHOOK_SECRET=

# Outbound dialing safety caps. Voice sequence steps are skipped once a lead
# reaches either cap; SMS steps still run.
MAX_CALL_ATTEMPTS=6
MAX_VOICEMAIL_ATTEMPTS=3
# Send a reminder SMS this many minutes before a booked consultation. 0 disables.
APPOINTMENT_REMINDER_MINUTES=30

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Use "calendly" for Calendly or "calcom" for Cal.com.
CALENDAR_PROVIDER=calendly
CALENDAR_DEFAULT_TIMEZONE=America/New_York

CALENDLY_API_KEY=
CALENDLY_API_BASE_URL=https://api.calendly.com
CALENDLY_EVENT_TYPE_URI=
CALENDLY_ADITYA_EVENT_TYPE_URI=
CALENDLY_ARCHIT_EVENT_TYPE_URI=
# Optional. Only set if your Calendly event type requires a custom location payload.
CALENDLY_LOCATION_KIND=
CALENDLY_LOCATION_VALUE=
CALENDLY_EVENT_GUESTS=

# Optional fallback provider. Leave blank if Calendly is active.
CAL_API_KEY=
CAL_API_BASE_URL=https://api.cal.com/v2
CAL_API_VERSION=2024-09-04
CAL_WEBHOOK_SECRET=
CAL_EVENT_TYPE_ID=
CAL_ADITYA_EVENT_TYPE_ID=
CAL_ARCHIT_EVENT_TYPE_ID=
CAL_DEFAULT_TIMEZONE=America/New_York

GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=
GMAIL_FROM_NAME=Ashmont Insurance
ADITYA_NOTIFICATION_EMAIL=
ARCHIT_NOTIFICATION_EMAIL=
APPOINTMENT_NOTIFICATION_CC=

ALERT_EMAIL_TO=
ALERT_SLACK_WEBHOOK_URL=
MOMENTUM_API_KEY=
MOMENTUM_API_BASE_URL=https://receiver.momentum.io
DASHBOARD_USERS_JSON=
DASHBOARD_TOKEN_SECRET=
DASHBOARD_TOKEN_TTL_MINUTES=1440
